"use client";

import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { useState } from "react";
import { supabase } from "@/Archive/lib/supabase";

export default function AppShell({ children }: { children: React.ReactNode }) {
  const pathname = usePathname();
  const router = useRouter();

  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [showSettingsMenu, setShowSettingsMenu] = useState(false);

  function installMessage() {
    alert(
      "Install Hey Chef:\n\nOn iPhone: tap Share, then Add to Home Screen.\n\nOn Android: tap the browser menu, then Install App or Add to Home Screen."
    );
  }

  async function logoutUser() {
    await supabase.auth.signOut();
    router.push("/signup");
  }

  const navItems = [
    { href: "/recipes", label: "Recipes" },
    { href: "/planner", label: "Meal Planner" },
    { href: "/shopping", label: "Shopping List" },
    { href: "/pantry", label: "My Pantry" },
  ];

  return (
    <main className="min-h-screen bg-[#f8efe6] px-5 py-6 pb-28 text-[#2b1a12] md:p-8">
      <section className="mx-auto max-w-6xl">
        <nav className="sticky top-0 z-50 -mx-5 mb-8 flex items-start justify-between gap-3 bg-[#f8efe6] px-5 py-4 md:-mx-6 md:px-6">
          <div className="flex flex-col">
            <Link href="/" className="text-3xl font-bold text-[#a63a0a]">
              Hey Chef™
            </Link>

            {pathname !== "/" && (
              <Link
                href="/"
                className="mt-1 text-left text-sm text-[#a63a0a]"
              >
                ← Return to Dashboard
              </Link>
            )}
          </div>

          <button
            onClick={() => setIsMenuOpen((open) => !open)}
            className="rounded-full bg-white px-4 py-3 text-3xl text-[#a63a0a] shadow md:hidden"
          >
            ☰
          </button>

          <div className="hidden items-center gap-10 text-lg md:flex">
            {navItems.map((item) => (
              <Link
                key={item.href}
                href={item.href}
                className={
                  pathname === item.href
                    ? "font-bold text-[#a63a0a] underline underline-offset-8"
                    : "text-[#a63a0a]"
                }
              >
                {item.label}
              </Link>
            ))}

            <div className="relative">
              <button
                onClick={() => setShowSettingsMenu((open) => !open)}
                className={
                  pathname === "/profile"
                    ? "font-bold text-[#a63a0a] underline underline-offset-8"
                    : "text-[#a63a0a]"
                }
              >
                ⚙️ Settings
              </button>

              {showSettingsMenu && (
                <div className="absolute right-0 top-10 z-50 w-56 rounded-2xl bg-white p-2 shadow-xl">
                  <Link
                    href="/profile"
                    onClick={() => setShowSettingsMenu(false)}
                    className="block w-full rounded-xl px-4 py-3 text-left hover:bg-[#fff4ef]"
                  >
                    👤 Profile
                  </Link>

                  <button
                    onClick={() => {
                      setShowSettingsMenu(false);
                      installMessage();
                    }}
                    className="block w-full rounded-xl px-4 py-3 text-left hover:bg-[#fff4ef]"
                  >
                    📱 Install App
                  </button>

                  <button
                    onClick={() => {
                      setShowSettingsMenu(false);
                      logoutUser();
                    }}
                    className="block w-full rounded-xl px-4 py-3 text-left hover:bg-[#fff4ef]"
                  >
                    ↪ Log Out
                  </button>
                </div>
              )}
            </div>
          </div>

          {isMenuOpen && (
            <div className="absolute right-5 top-20 z-50 w-64 rounded-3xl bg-white p-4 shadow-xl md:hidden">
              <p className="mb-2 px-4 text-xs uppercase tracking-[0.2em] text-[#a63a0a]">
                Settings
              </p>

              <Link
                href="/profile"
                onClick={() => setIsMenuOpen(false)}
                className="block w-full rounded-2xl px-4 py-3 text-left text-[#2b1a12] hover:bg-[#fff4ef]"
              >
                👤 Profile
              </Link>

              <button
                onClick={() => {
                  setIsMenuOpen(false);
                  installMessage();
                }}
                className="block w-full rounded-2xl px-4 py-3 text-left text-[#2b1a12] hover:bg-[#fff4ef]"
              >
                📱 Install App
              </button>

              <button
                onClick={() => {
                  setIsMenuOpen(false);
                  logoutUser();
                }}
                className="block w-full rounded-2xl px-4 py-3 text-left text-[#2b1a12] hover:bg-[#fff4ef]"
              >
                ↪ Log Out
              </button>
            </div>
          )}
        </nav>

        {children}

        <footer className="mt-20 border-t border-[#ead7c8] pt-8 text-center text-sm text-[#6d5549]">
          <p>© 2020–2026 Hey Chef™. All rights reserved.</p>

          <div className="mt-3 flex justify-center gap-6">
            <Link href="/privacy">Privacy</Link>
            <Link href="/terms">Terms</Link>
            <Link href="/contact">Contact</Link>
          </div>
        </footer>
      </section>

      <nav className="fixed bottom-0 left-0 right-0 z-50 grid grid-cols-5 border-t border-[#ead7c8] bg-[#fffaf3] text-xs shadow-2xl md:hidden">
        <Link
          href="/recipes"
          className={`px-2 py-3 text-center ${
            pathname === "/recipes" ? "font-bold text-[#a63a0a]" : "text-[#6d5549]"
          }`}
        >
          Recipes
        </Link>

        <Link
          href="/planner"
          className={`px-2 py-3 text-center ${
            pathname === "/planner" ? "font-bold text-[#a63a0a]" : "text-[#6d5549]"
          }`}
        >
          Planner
        </Link>

        <Link
          href="/shopping"
          className={`px-2 py-3 text-center ${
            pathname === "/shopping" ? "font-bold text-[#a63a0a]" : "text-[#6d5549]"
          }`}
        >
          Shopping
        </Link>

        <Link
          href="/pantry"
          className={`px-2 py-3 text-center ${
            pathname === "/pantry" ? "font-bold text-[#a63a0a]" : "text-[#6d5549]"
          }`}
        >
          Pantry
        </Link>

        <Link
          href="/profile"
          className={`px-2 py-3 text-center ${
            pathname === "/profile" ? "font-bold text-[#a63a0a]" : "text-[#6d5549]"
          }`}
        >
          Profile
        </Link>
      </nav>
    </main>
  );
}